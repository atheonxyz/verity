root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{swift}]
indent_size = 4

[*.{kt,kts}]
indent_size = 4

[*.{ts,js,json}]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[*.{c,h}]
indent_size = 4

[*.{toml}]
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
