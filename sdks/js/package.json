{
  "name": "@atheonxyz/verity",
  "version": "0.3.2-beta",
  "description": "Zero-knowledge proof SDK for Node.js and browsers",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/atheonxyz/verity",
    "directory": "sdks/js"
  },
  "type": "module",
  "main": "./dist/node/index.js",
  "module": "./dist/browser/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "node": {
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs"
      },
      "browser": {
        "import": "./dist/browser/index.js"
      },
      "default": "./dist/browser/index.js"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts && tsc --emitDeclarationOnly && node scripts/copy-wasm.mjs",
    "test": "npm run test:src && npm run test:dist",
    "test:src": "vitest run",
    "test:dist": "npm run build && node scripts/smoke-dist.mjs",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@noir-lang/noir_js": "1.0.0-beta.19",
    "@noir-lang/acvm_js": "1.0.0-beta.19"
  },
  "peerDependenciesMeta": {
    "@noir-lang/noir_js": { "optional": true },
    "@noir-lang/acvm_js": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "@noir-lang/acvm_js": "1.0.0-beta.19",
    "@noir-lang/noir_js": "1.0.0-beta.19",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
